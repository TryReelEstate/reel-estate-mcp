{
  "name": "reel-estate-mcp",
  "version": "0.3.0",
  "description": "Self-hosted MCP server for the Reel Estate backend — an OAuth client of the backend's /mcp endpoint that adds local-filesystem superpowers (e.g. uploading local images).",
  "type": "module",
  "bin": {
    "reel-estate-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "smoke": "tsx scripts/smoke.ts",
    "diag": "tsx scripts/diag-oauth.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^17.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
