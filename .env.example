# --- Backend MCP endpoint (the auth authority) ---
# The backend ORIGIN that hosts the embedded /mcp endpoint (the API host, NOT the
# marketing site). A bare origin gets "/mcp" appended automatically.
# OPTIONAL — defaults to production (https://api.tryreelestate.com). Set it only
# for staging or a self-hosted backend.
#   Production: https://api.tryreelestate.com   (default)
#   Local:     http://localhost:3001
MCP_SERVER_URL=

# --- Optional ---
# Loopback port the browser is redirected back to during OAuth. Default 8765.
# Must be free on the machine running this server.
MCP_OAUTH_CALLBACK_PORT=8765

# Where to cache the OAuth client registration + tokens.
# Default: ~/.reel-estate-mcp
MCP_OAUTH_STORE_DIR=

# Override the OAuth scope. Leave blank to negotiate from server metadata.
MCP_OAUTH_SCOPE=

# Pre-registered public OAuth client id. Built-in defaults are bundled for the
# Reel Estate hosted backends (production api.tryreelestate.com and staging), so
# you can leave this blank for those. Set it ONLY for a backend on a different
# Clerk instance (e.g. self-hosted): create a public OAuth app in that Clerk
# dashboard (PKCE, token_endpoint_auth_method=none, redirect
# http://localhost:8765/callback) and paste its client_id here. A client id is
# only valid on the instance that created it. Public + PKCE — no secret to share.
MCP_OAUTH_CLIENT_ID=

# Set to 1/true to block all non-GET requests (read-only mode). Default off.
MCP_READONLY=

# NOTE: No CLERK_SECRET_KEY or MCP_USER anymore. You authenticate by browser
# login on first use; tokens are cached under MCP_OAUTH_STORE_DIR. To switch
# users or re-authorize, delete that directory.
