# MongoDB connection string for the Reel Estate backend database.
# Point this at STAGING (read-only intent) unless you know what you're doing.
# Example staging value (database: reel-estate-v2):
#   mongodb+srv://<user>:<password>@reel-estate.dumnqll.mongodb.net/reel-estate-v2?retryWrites=true&w=majority&family=4
MONGODB_URI=

# Optional: cap how many documents any list tool can return in a single call.
# Defaults to 100. Hard ceiling that user-supplied `limit` cannot exceed.
MCP_MAX_LIMIT=100
