# --- Clerk (authenticates the MCP server AS a user) ---
# Clerk Backend API secret key. MUST belong to the SAME Clerk instance as the
# API you point at:
#   - test key (sk_test_...) -> staging / localhost
#   - live key (sk_live_...) -> production (https://tryreelestate.com)
# A mismatched key authenticates at Clerk but the API returns 401 INVALID_TOKEN.
CLERK_SECRET_KEY=

# The user to act as: an email address OR a Clerk user id (user_...).
MCP_USER=jeff@tryreelestate.com

# --- API target ---
# Base URL of the backend. A bare origin gets "/api/v1" appended automatically.
# Production: https://tryreelestate.com   Local: http://localhost:3001
API_BASE_URL=https://tryreelestate.com

# --- Optional ---
# Requested lifetime (seconds) for each minted session token. Default 3600.
MCP_TOKEN_TTL_SECONDS=3600
# Set to 1/true to block all non-GET requests (read-only mode). Default off.
MCP_READONLY=
